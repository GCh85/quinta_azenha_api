            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@exemplo.pt\",\n  \"telefone\": \"912345678\",\n  \"assunto\": \"Prova de Arinto\",\n  \"dataPretendida\": \"2026-05-20T10:00:00Z\",\n  \"numeroPessoas\": 2,\n  \"mensagem\": \"Gostaria de fazer uma reserva para prova de vinho.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", function() { pm.expect(pm.response.status).to.eql(201); });",
                  "pm.test(\"Retorna reserva com disponibilidade\", function() { var jsonData = pm.response.json(); pm.expect(jsonData.reserva).to.be.ok; pm.expect(jsonData.disponibilidade).to.be.ok; });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /reservas - Listar (requer auth)",
          "request": {
