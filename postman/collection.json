{
  "info": {
    "name": "Quinta da Azenha API - UC00605",
    "description": "Coleção de testes para o Projeto Final UC00605 - API REST Quinta da Azenha",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5169/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Vinhos",
      "item": [
        {
          "name": "GET /vinhos - Listar todos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vinhos"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function() { pm.expect(pm.response.status).to.eql(200); });",
                  "pm.test(\"Retorna array de vinhos\", function() { var jsonData = pm.response.json(); pm.expect(Array.isArray(jsonData)).to.be.true; });",
                  "pm.test(\"Tem 5 vinhos\", function() { var jsonData = pm.response.json(); pm.expect(jsonData.length).to.eql(5); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /vinhos/{id} - Por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vinhos/1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 200\", function() { pm.expect(pm.response.status).to.eql(200); });", "pm.test(\"Retorna vinho com ID 1\", function() { var jsonData = pm.response.json(); pm.expect(jsonData.id).to.eql(1); });"]
              }
            }
          ]
        },
        {
          "name": "GET /vinhos/destaque - Em destaque",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vinhos/destaque"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 200\", function() { pm.expect(pm.response.status).to.eql(200); });", "pm.test(\"Vinho em destaque\", function() { var jsonData = pm.response.json(); pm.expect(jsonData.destaque).to.be.true; });"]
              }
            }
          ]
        },
        {
          "name": "GET /vinhos/tipo/{tipo} - Filtrar por tipo",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vinhos/tipo/Branco"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 200\", function() { pm.expect(pm.response.status).to.eql(200); });", "pm.test(\"Retorna vinhos Brancos\", function() { var jsonData = pm.response.json(); jsonData.forEach(function(v) { pm.expect(v.tipo).to.eql(\"Branco\"); }); });"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Experiências",
      "item": [
        {
          "name": "GET /experiencias - Listar ativas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/experiencias"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function() { pm.expect(pm.response.status).to.eql(200); });",
                  "pm.test(\"Retorna 4 experiências\", function() { var jsonData = pm.response.json(); pm.expect(jsonData.length).to.eql(4); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /experiencias/{id} - Por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/experiencias/1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 200\", function() { pm.expect(pm.response.status).to.eql(200); });", "pm.test(\"Retorna Prova de Arinto\", function() { var jsonData = pm.response.json(); pm.expect(jsonData.nome).to.eql(\"Prova de Arinto\"); });"]
              }
            }
          ]
        },
        {
          "name": "POST /experiencias - Criar (requer auth)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/experiencias",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Nova Experiência Teste\",\n  \"descricao\": \"Experiência de teste\",\n  \"preco\": 50.00,\n  \"duracaoMinutos\": 120,\n  \"lotacaoMaxima\": 10,\n  \"epoca\": null,\n  \"imagem\": \"teste.png\",\n  \"ativa\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 201 ou 401\", function() { pm.expect([201, 401]).to.include(pm.response.status); });"]
              }
            }
          ]
        },
        {
          "name": "DELETE /experiencias/{id} - Desativar (requer auth)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/experiencias/99",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 204 ou 401/404\", function() { pm.expect([204, 401, 404]).to.include(pm.response.status); });"]
              }
            }
          ]
        }
      ]
    },
    {
