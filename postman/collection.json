                "exec": ["pm.test(\"Status 200 ou 401\", function() { pm.expect([200, 401]).to.include(pm.response.status); });"]
              }
            }
          ]
        },
        {
          "name": "GET /reservas/{id} - Por ID (requer auth)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reservas/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 200 ou 401/404\", function() { pm.expect([200, 401, 404]).to.include(pm.response.status); });"]
              }
            }
          ]
        },
        {
          "name": "PUT /reservas/{id}/estado - Atualizar estado (requer auth)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/reservas/1/estado",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "\"Confirmada\""
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 200 ou 401/404/400\", function() { pm.expect([200, 401, 404, 400]).to.include(pm.response.status); });"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Autenticação",
      "item": [
        {
          "name": "POST /auth/register - Registar admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@quintaazenha.pt\",\n  \"password\": \"Admin123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test(\"Status 201 ou 409 (já existe)\", function() { pm.expect([201, 409]).to.include(pm.response.status); });"]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login - Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@quintaazenha.pt\",\n  \"password\": \"Admin123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function() { pm.expect(pm.response.status).to.eql(200); });",
                  "pm.test(\"Retorna token JWT\", function() { var jsonData = pm.response.json(); pm.expect(jsonData.token).to.be.ok; pm.collectionVariables.set(\"authToken\", jsonData.token); });"
                ]
              }
            }
          ]
        }
      ]
    },
